{
  "rewrites": [
    {
      "source": "/api/counter/up",
      "destination": "https://api.counterapi.dev/v2/sandesh-vermas-team-4624/sandyport_visits/up"
    },
    {
      "source": "/api/counter/down",
      "destination": "https://api.counterapi.dev/v2/sandesh-vermas-team-4624/sandyport_visits/down"
    },
    {
      "source": "/api/counter",
      "destination": "https://api.counterapi.dev/v2/sandesh-vermas-team-4624/sandyport_visits/"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://app.cal.com; style-src 'self' 'unsafe-inline' https://app.cal.com; font-src 'self'; img-src 'self' data: https://ghchart.rshah.org https://cdn.jsdelivr.net https://www.sandeshverma.dev https://app.cal.com; media-src 'self'; connect-src 'self' https://gist.githubusercontent.com https://vitals.vercel-insights.com https://api.cal.com https://app.cal.com; frame-src https://cal.com https://app.cal.com; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
